# Server
PORT=5000

# MongoDB Atlas (required for Vector Search)
# IMPORTANT: Add your IP to MongoDB Atlas → Network Access → Add IP Address
# For development: Use 0.0.0.0/0 (allows all IPs)
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/opsmind?retryWrites=true&w=majority

# Google AI (Gemini) - get key from https://aistudio.google.com/apikey
GOOGLE_AI_API_KEY=your_google_ai_api_key_here

# CORS - frontend origin
FRONTEND_URL=http://localhost:5173
